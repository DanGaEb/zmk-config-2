" Primary movement
noremap n h
noremap e j
noremap u k
noremap i l

" Reverse
noremap h n
noremap j e
noremap k u
noremap l i

" 3. Capitalised
" h(Next match) -> H(Prev match)
" j(End of word) -> J(Join lines)
" k(Undo) -> K(Help/Lookup)
" l(Insert) -> L(Move to bottom of screen)
noremap N H
noremap E J
noremap U K
noremap I L

noremap H N
noremap J E
noremap K U
noremap L I

" Window navigation
nnoremap <C-w>n <C-w>h
nnoremap <C-w>e <C-w>j
nnoremap <C-w>u <C-w>k
nnoremap <C-w>i <C-w>l

" Fold navigation
nnoremap ze zj
nnoremap zu zk